# Gemma via the Gemini API. Get a key at https://aistudio.google.com/apikey
# Copy this file to .env.local and paste your key. FloWise works WITHOUT a key
# too (it falls back to sensible canned text), so this is optional for demos.
GEMINI_API_KEY=

# Optional: override the Gemma model (defaults to gemma-4-26b-a4b-it).
# GEMMA_MODEL=gemma-4-26b-a4b-it
